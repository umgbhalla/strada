{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "rootDir": "src",
    "outDir": "dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ESNext",
    "lib": [
      "ESNext"
    ],
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "src"
  ]
}
