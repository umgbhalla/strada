{
  "name": "strada",
  "version": "0.0.1",
  "description": "CLI for Strada — open-source OpenTelemetry observability on Tinybird",
  "type": "module",
  "bin": "dist/cli.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist *.tsbuildinfo && tsc && chmod +x dist/cli.js",
    "prepublishOnly": "pnpm build",
    "cli": "tsx src/cli",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@tinybirdco/sdk": "^0.0.64",
    "goke": "^6.3.1",
    "picocolors": "^1.1.1",
    "spiceflow": "^1.18.0",
    "string-dedent": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/strada",
    "directory": "cli"
  },
  "homepage": "https://github.com/remorses/strada",
  "bugs": "https://github.com/remorses/strada/issues",
  "keywords": [
    "strada",
    "opentelemetry",
    "otel",
    "observability",
    "tinybird",
    "cli"
  ],
  "license": "MIT",
  "author": "remorses <beats.by.morse@gmail.com>"
}
