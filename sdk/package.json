{
  "name": "@strada.sh/sdk",
  "version": "0.4.0",
  "description": "OTel-first Strada SDK. Sentry-like error capture and auto-instrumentation for Node.js and browsers, powered by OpenTelemetry.",
  "keywords": [
    "strada",
    "opentelemetry",
    "otel",
    "error-tracking",
    "observability",
    "tracing",
    "sdk"
  ],
  "homepage": "https://github.com/remorses/strada",
  "bugs": "https://github.com/remorses/strada/issues",
  "license": "MIT",
  "author": "remorses <beats.by.morse@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/strada",
    "directory": "sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "workerd": "./dist/cloudflare.js",
      "browser": "./dist/browser.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./better-auth": {
      "types": "./dist/better-auth.d.ts",
      "default": "./dist/better-auth.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "default": "./dist/shared.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "imports": {
    "#log-format": {
      "browser": "./src/log-format-json.ts",
      "workerd": "./src/log-format-json.ts",
      "development": "./src/log-format-node.ts",
      "node": {
        "types": "./dist/log-format-node.d.ts",
        "default": "./dist/log-format-node.js"
      },
      "default": {
        "types": "./dist/log-format-json.d.ts",
        "default": "./dist/log-format-json.js"
      }
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "rimraf dist \"*.tsbuildinfo\" && pnpm build",
    "test": "vitest run",
    "typecheck": "tsc",
    "bundle:browser": "esbuild src/browser.ts --bundle --format=esm --platform=browser --target=es2022 --conditions=browser --outfile=dist/bundle-browser.js --metafile=dist/bundle-browser-meta.json && node -e \"const m=JSON.parse(require('fs').readFileSync('dist/bundle-browser-meta.json','utf8')); const out=Object.values(m.outputs)[0]; console.log('Browser bundle:', (out.bytes/1024).toFixed(1)+'kB', '('+Object.keys(out.inputs).length+' modules)')\"",
    "bundle:node": "esbuild src/node.ts --bundle --format=esm --platform=node --target=node18 --main-fields=module,main --outfile=dist/bundle-node.js --metafile=dist/bundle-node-meta.json && node -e \"const m=JSON.parse(require('fs').readFileSync('dist/bundle-node-meta.json','utf8')); const out=Object.values(m.outputs)[0]; console.log('Node bundle:', (out.bytes/1024).toFixed(1)+'kB', '('+Object.keys(out.inputs).length+' modules)')\"",
    "bundle:check": "pnpm bundle:browser && pnpm bundle:node"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/sdk-trace-web": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "better-auth": "https://pkg.pr.new/better-auth@9489",
    "esbuild": "^0.28.0",
    "rimraf": "^6.0.1",
    "vite": "^8.0.13"
  }
}
