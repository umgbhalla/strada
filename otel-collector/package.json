{
  "name": "otel-collector",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "OTel collector on Cloudflare Workers. Receives OTLP HTTP/JSON traces, logs, and metrics and forwards to Tinybird or ClickHouse as NDJSON.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:localhost": "tsx scripts/dev-localhost.ts",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:integration": "vitest run src/collector-integration.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "spiceflow": "^1.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/node": "^22.1.0",
    "tsx": "^4.17.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1",
    "wrangler": "^4.5.1"
  }
}
