{
  "name": "otel-collector",
  "version": "0.0.1",
  "private": true,
  "description": "OTel collector on Cloudflare Workers. Receives OTLP HTTP/JSON traces, logs, and metrics and forwards to Tinybird or ClickHouse as NDJSON.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:localhost": "tsx scripts/dev-localhost.ts",
    "deploy": "wrangler deploy --env preview",
    "deploy:prod": "wrangler deploy",
    "test": "vitest run",
    "test:integration": "vitest run src/collector-integration.test.ts",
    "typecheck": "tsc",
    "types": "wrangler types",
    "secrets": "sigillo run --env preview --mount .env.preview --mount-format env -- wrangler secret bulk --env preview .env.preview && sigillo run --env prod --mount .env.prod --mount-format env -- wrangler secret bulk --env=\"\" .env.prod"
  },
  "dependencies": {
    "@strada.sh/sdk": "workspace:^",
    "spiceflow": "1.20.0-rsc.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.17.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.5.1"
  }
}
