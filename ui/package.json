{
  "name": "@strada.sh/ui",
  "version": "0.0.1",
  "description": "Reusable Strada observability UI components and demos.",
  "keywords": [
    "strada",
    "opentelemetry",
    "observability",
    "react",
    "ui"
  ],
  "homepage": "https://github.com/remorses/strada",
  "bugs": "https://github.com/remorses/strada/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/strada",
    "directory": "ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "dev": "vite dev --port 3456",
    "build": "vite build && tsc -p tsconfig.json",
    "chart:render": "tsx scripts/render-chart.ts",
    "typecheck": "tsc -p tsconfig.json",
    "start": "node dist/rsc/index.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./echarts-options": {
      "types": "./dist/lib/echarts-options.d.ts",
      "default": "./dist/lib/echarts-options.js"
    },
    "./styles.css": "./src/globals.css",
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "dependencies": {
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@remixicon/react": "^4.9.0",
    "@strada.sh/sdk": "workspace:^",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "date-fns": "^4.1.0",
    "dotted-map": "^3.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "spiceflow": "1.22.0-rsc.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "@types/d3-scale": "^4.0.9",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "echarts": "^6.0.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.13"
  },
  "peerDependencies": {
    "echarts": "^6.0.0"
  }
}
