{
  "name": "example-app",
  "private": true,
  "type": "module",
  "description": "Minimal Spiceflow app that sends example telemetry to Strada.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser-verify": "vitest run src/browser-verify.test.ts"
  },
  "dependencies": {
    "@strada.sh/sdk": "workspace:^",
    "spiceflow": "1.26.0-rsc.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "playwright": "^1.52.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
